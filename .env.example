# Copie para .env local ou configure no painel da Vercel (Environment Variables).

# PostgreSQL — Supabase: Connect → ORM → Prisma (use as duas strings do painel)
# Troque [YOUR-PASSWORD]; caracteres especiais na senha precisam ser codificados na URL.
# Não use o host db.xxx.supabase.co aqui — use o pooler (migrate/db push usam DIRECT_URL).
DATABASE_URL="postgresql://postgres.SEU_REF:SUA_SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.SEU_REF:SUA_SENHA@aws-0-REGIAO.pooler.supabase.com:5432/postgres"

# NextAuth — gere um segredo forte: openssl rand -base64 32
# Também assina o token do WebSocket (Socket.IO). Opcionalmente AUTH_SECRET com o mesmo valor.
NEXTAUTH_SECRET=
# URL pública do app (obrigatório em produção)
AUTH_URL="https://seu-projeto.vercel.app"

# Dev/produção com chat em tempo real: use `npm run dev` / `npm start` (server.ts + Socket.IO na mesma porta).
# `next dev` sozinho não ativa o WebSocket.

# Pusher (Channels) — apenas notificações no sininho; chat usa Socket.IO
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# Opcional: Pusher self-hosted (deixe vazio para usar cluster)
# PUSHER_HOST=
# PUSHER_PORT=
# NEXT_PUBLIC_PUSHER_HOST=
# NEXT_PUBLIC_PUSHER_PORT=

# Opcional: MongoDB (ex.: Docker Compose acima → porta 27018 no host)
# MONGODB_URI=mongodb://localhost:27018
